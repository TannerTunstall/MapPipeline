  <Document>
    <name>Israel Rocket Alerts</name>
    <description>Real-time rocket and missile alerts in Israel. Updated every 5 minutes. Last updated: Mon, Apr 6, 2026 12:35:14 AM (Israel Time)</description>

    <Style id="poly-critical">
      <LineStyle><color>ff0000ff</color><width>2</width></LineStyle>
      <PolyStyle><color>600000ff</color><outline>1</outline></PolyStyle>
      <BalloonStyle>
        <bgColor>ff1a1a2e</bgColor>
        <textColor>ffffffff</textColor>
      </BalloonStyle>
    </Style>
