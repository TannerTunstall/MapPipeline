    <!-- Point Styles -->
    <Style id="alert-critical">
        <IconStyle>
            <color>ff0000ff</color>
            <scale>1.4</scale>
            <Icon><href>http://maps.google.com/mapfiles/kml/shapes/caution.png</href></Icon>
        </IconStyle>
        <LabelStyle><color>ff0000ff</color><scale>0.9</scale></LabelStyle>
    </Style>
    <Style id="alert-recent">
