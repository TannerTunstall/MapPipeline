      <PolyStyle><color>400080ff</color><outline>1</outline></PolyStyle>
      <BalloonStyle>
        <bgColor>ff1a1a2e</bgColor>
        <textColor>ffffffff</textColor>
      </BalloonStyle>
    </Style>
    <Style id="poly-moderate">
